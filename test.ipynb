    "for fruit in fruits:\n",
    "    print(fruit)\n",
    "\n",
    "# 조건을 만족할 때까지 반복\n",
    "count = 1\n",
    "while count <= 5:\n",
    "    print(f\"현재 값: {count}\")\n",
    "    count += 1"
